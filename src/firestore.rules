rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Stories collection - publicly readable, writable by everyone for guest submissions
    match /stories/{storyId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // Comments/replies collection - publicly readable and writable
    match /comments/{commentId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // User profiles - readable and writable to support profile synchronization
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
