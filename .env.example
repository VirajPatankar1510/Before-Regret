# ==============================================================================
# BeforeRegret - PRODUCTION ENVIRONMENT VARIABLES & SECRETS VAULT
# ==============================================================================
# IMPORTANT SECURITY WARNING:
# Do NOT commit live/production API keys, private certificates, or secret values 
# directly into this repository or any client-side codebase.
#
# Instead, store these variables securely inside your cloud hosting environment's 
# native secrets manager (e.g., Google Cloud Run Secrets, GCP Secret Manager, or 
# GitHub Repository Secrets for CI/CD deployment pipelines).
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------
# APP_URL: The public production URL where the application is hosted.
# AI Studio / Cloud Run automatically injects this at runtime.
APP_URL="https://before-regret.com"

# NODE_ENV: Set to 'production' for optimal performance in live deployments.
NODE_ENV="production"


# ------------------------------------------------------------------------------
# 2. GEMINI AI SERVICE
# ------------------------------------------------------------------------------
# GEMINI_API_KEY: Required for executing server-side Gemini LLM capabilities.
# In production, inject this securely using Cloud Run / Secret Manager.
GEMINI_API_KEY="YOUR_SECURE_GEMINI_API_KEY"


# ------------------------------------------------------------------------------
# 3. RAZORPAY INTEGRATION (SECURE PAYMENT GATEWAY)
# ------------------------------------------------------------------------------
# RAZORPAY_KEY_ID: The public key identifier issued by Razorpay dashboard.
# Prefix client-accessible keys with 'VITE_' to expose them securely in Vite.
VITE_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxx"

# RAZORPAY_KEY_SECRET: Your private API secret key for backend verification.
# CRITICAL: Keep this strictly server-side. Do NOT prefix with 'VITE_'.
RAZORPAY_KEY_SECRET="YOUR_SECURE_RAZORPAY_KEY_SECRET"



# ------------------------------------------------------------------------------
# 4. CLERK AUTHENTICATION CONFIGURATION
# ------------------------------------------------------------------------------
# Set your Clerk Publishable Key here. You can get this from your Clerk Dashboard:
# https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY="pk_test_Y2xlYW4tc25haWwtNDUuY2xlcmsuYWNjb3VudHMuZGV2JA"
CLERK_SECRET_KEY="YOUR_CLERK_SECRET_KEY"


# ------------------------------------------------------------------------------
# 6. EXTERNAL MAPS / LOCATION SERVICES
# ------------------------------------------------------------------------------
# MAPMYINDIA / MAPPLS API CREDENTIALS:
# Used for address matching and neighborhood spatial queries.
MAPMYINDIA_CLIENT_ID="YOUR_MAPMYINDIA_CLIENT_ID"
MAPMYINDIA_CLIENT_SECRET="YOUR_MAPMYINDIA_CLIENT_SECRET"
