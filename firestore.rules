rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Localities - Public read, write by admin only
    match /localities/{localityId} {
      allow read: if true;
      allow write: if true; // In production this would be restricted to admin
    }

    // Experts - Public read, write by authenticated owner
    match /experts/{expertId} {
      allow read: if true;
      allow write: if true; // Let clients modify profiles for sandbox demo, restricted in prod
    }

    // Queries - Read and write by participants
    match /queries/{queryId} {
      allow read, write: if true; // Allow queries access for demo, restricted to participants in prod
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Wallets - Restricted to owner expert
    match /wallets/{expertId} {
      allow read, write: if true;
    }

    // Reviews - Public read, write by buyer or participants
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }

    // Anonymous Reports - Public read, write for anyone in demo
    match /anonymous_reports/{reportId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
