{
  "entities": {
    "Locality": {
      "title": "Locality or Residential Society",
      "description": "A residential society or neighborhood profile containing structural quality indicators",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "pincode": { "type": "string" },
        "builder": { "type": "string" },
        "expertCount": { "type": "integer" },
        "rating": { "type": "number" },
        "waterTankerDependency": { "type": "integer" },
        "parkingDisputes": { "type": "integer" },
        "powerCutHistory": { "type": "integer" },
        "bachelorPetRules": { "type": "integer" },
        "monsoonFlooding": { "type": "integer" },
        "noiseIndex": { "type": "integer" }
      },
      "required": ["id", "name", "city", "pincode"]
    },
    "ExpertProfile": {
      "title": "Resident Expert Profile",
      "description": "Verified resident expert details representing local neighborhood intelligence",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "bio": { "type": "string" },
        "localityId": { "type": "string" },
        "localityName": { "type": "string" },
        "city": { "type": "string" },
        "verified": { "type": "boolean" },
        "memberSince": { "type": "string" },
        "questionsAnsweredCount": { "type": "integer" },
        "responseRate": { "type": "integer" },
        "responseTime": { "type": "string" },
        "rating": { "type": "number" },
        "pricingPerQuery": { "type": "integer" },
        "kycStatus": { "type": "string", "enum": ["NOT_STARTED", "PENDING", "VERIFIED", "REJECTED"] },
        "active": { "type": "boolean" },
        "expertiseTags": { "type": "array" }
      },
      "required": ["id", "userId", "fullName", "localityId", "localityName", "city"]
    },
    "DirectQuery": {
      "title": "Direct Resident Query",
      "description": "An escrow-protected micro-transaction query containing buyer questions and expert responses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "expertId": { "type": "string" },
        "expertName": { "type": "string" },
        "localityId": { "type": "string" },
        "localityName": { "type": "string" },
        "queryText": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ACCEPTED", "ANSWERED", "REFUNDED", "DISPUTED"] },
        "pricePaid": { "type": "integer" },
        "expertEarnings": { "type": "integer" },
        "createdAt": { "type": "string" },
        "answeredAt": { "type": "string" },
        "answerText": { "type": "string" },
        "packageOption": { "type": "string", "enum": ["QUICK", "BUNDLE", "AUDIT"] },
        "razorpayOrderId": { "type": "string" },
        "isDisputed": { "type": "boolean" },
        "disputeReason": { "type": "string" }
      },
      "required": ["id", "buyerId", "expertId", "queryText", "status", "pricePaid", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message Log",
      "description": "An asynchronous message item within an active direct query thread",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "queryId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["buyer", "expert"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string" },
        "mapPin": { "type": "object" },
        "imageAttachment": { "type": "string" }
      },
      "required": ["id", "queryId", "senderId", "senderRole", "text", "createdAt"]
    },
    "Wallet": {
      "title": "Expert Wallet Ledger",
      "description": "Ledger representing completed micro-transaction payout balances and bank destinations",
      "type": "object",
      "properties": {
        "expertId": { "type": "string" },
        "availableBalance": { "type": "integer" },
        "heldBalance": { "type": "integer" },
        "totalWithdrawn": { "type": "integer" },
        "upiId": { "type": "string" },
        "bankAccountNumber": { "type": "string" },
        "ifscCode": { "type": "string" }
      },
      "required": ["expertId", "availableBalance", "heldBalance", "totalWithdrawn"]
    },
    "Review": {
      "title": "Resident review score",
      "description": "Verified star reviews and comments left by buyers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "queryId": { "type": "string" },
        "buyerName": { "type": "string" },
        "expertId": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "queryId", "buyerName", "expertId", "rating", "comment", "createdAt"]
    },
    "AnonymousReport": {
      "title": "Anonymous Community Report",
      "description": "Unfiltered community warnings and reports posted anonymously",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "localityId": { "type": "string" },
        "tag": { "type": "string", "enum": ["WATER", "PARKING", "NOISE", "MAIDS", "MANAGEMENT"] },
        "tagLabel": { "type": "string" },
        "tagStyle": { "type": "string" },
        "comment": { "type": "string" },
        "timestamp": { "type": "string" },
        "block": { "type": "string" }
      },
      "required": ["id", "localityId", "tag", "tagLabel", "comment", "timestamp", "block"]
    }
  },
  "firestore": {
    "/localities/{localityId}": {
      "schema": "Locality",
      "description": "Collection of Indian apartments, residential societies, and localities"
    },
    "/experts/{expertId}": {
      "schema": "ExpertProfile",
      "description": "Directory of verified neighborhood resident experts"
    },
    "/queries/{queryId}": {
      "schema": "DirectQuery",
      "description": "Escrow protected paid consultation inquiries"
    },
    "/queries/{queryId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Asynchronous chat communication threads associated with inquiries"
    },
    "/wallets/{expertId}": {
      "schema": "Wallet",
      "description": "Expert financial statements and payout configurations"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Historical buyer star feedback ratings"
    },
    "/anonymous_reports/{reportId}": {
      "schema": "AnonymousReport",
      "description": "Unfiltered anonymous community warnings and complaints"
    }
  }
}
